<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox spacing="15" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="view.AdminController">
  <Label text="Panel de Administración" styleClass="titulo"/>
  <TextField fx:id="tituloField" promptText="Título"/>
  <TextField fx:id="compositorField" promptText="Compositor"/>
  <ComboBox fx:id="tipoBox"/>
  <TextField fx:id="precioField" promptText="Precio"/>
  <HBox spacing="10" alignment="CENTER">
    <Button text="Añadir" onAction="#handleAdd"/>
    <Button text="Actualizar" onAction="#handleUpdate"/>
    <Button text="Eliminar" onAction="#handleDelete"/>
  </HBox>
  <ListView fx:id="listaPartituras" prefHeight="150"/>
  <Button text="Cargar CSV" onAction="#handleCSV"/>
  <Button text="Cerrar sesión" onAction="#handleLogout"/>
  <Label fx:id="mensajeLabel"/>
</VBox>
